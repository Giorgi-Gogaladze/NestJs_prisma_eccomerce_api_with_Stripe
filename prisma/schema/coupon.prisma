model Coupon {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique
  discountPerc Int
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  //rel
  orders Order[]

  @@map("coupons")
}
