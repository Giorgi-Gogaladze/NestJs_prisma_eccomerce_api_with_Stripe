model InventoryLog {
    id           String                @id @default(uuid()) @db.Uuid
    changeAmount Int
    reason       InventoryChangeReason
    createdAt    DateTime              @default(now())

    //rel
    variantId String  @db.Uuid
    product_variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
}

enum InventoryChangeReason {
    SALE
    RETURN
    ADJUSTMENT
    OTHER
}
