model User {
    id           String   @id @default(uuid())
    firstName    String
    lastName     String
    email        String   @unique
    password     String
    role         Role     @default(USER)
    refreshToken String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@map("users")
}

enum Role {
    ADMIN
    USER
}
