model User {
    id              String       @default(uuid()) @id
    firstName       String 
    lastName        String
    email           String    @unique
    password        String  
    role            Role      @default(USER) 
    refreshToken    String? 
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt
}

enum Role {
    ADMIN
    USER
}