model Brand {
    id          String  @id @default(uuid()) @db.Uuid
    name        String  @unique
    slug        String  @unique
    logoImg     String?
    description String?
    isActive    Boolean @default(true)
    logoPublicId String?  //(ჩემთვის) ეს ქლაუდინარის ფაბლიქ აიდია

    products Product[]

    @@map("brands")
}
