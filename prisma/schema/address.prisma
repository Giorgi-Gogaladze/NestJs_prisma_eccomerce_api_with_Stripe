model Address {
  id          String    @id @default(uuid())
  city        String
  street      String
  zipCode     String
  isDefault   Boolean   @default(false)
  phoneNumber String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt


  //relations
  userId String
  user User @relation(fields: [userId], references: [id])

  @@map("addresses")
}